# =============================================================================
# Sophia — variaveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env real no Git (ele esta no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE_URL — connection string do Postgres
# -----------------------------------------------------------------------------
# DEV LOCAL (com Docker, ver docker-compose.yml na raiz):
DATABASE_URL="postgresql://sophia:sophia@localhost:5432/sophia_dev?schema=public"

# DEV LOCAL (sem Docker, com Postgres ja instalado):
# DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/sophia_dev?schema=public"

# PRODUCAO (Neon / Vercel Postgres / Supabase):
# DATABASE_URL="postgresql://user:pass@host.neon.tech/sophia?sslmode=require"

# -----------------------------------------------------------------------------
# JWT_SECRET — chave forte para assinar tokens de sessao
# -----------------------------------------------------------------------------
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-uma-chave-de-no-minimo-64-caracteres-aleatorios"

# -----------------------------------------------------------------------------
# RESEND_API_KEY — para envio de e-mails (verificacao, reset de senha)
# -----------------------------------------------------------------------------
# Crie em https://resend.com (free tier: 100 e-mails/dia, 3000/mes).
# Sem essa chave, cadastro funciona mas o e-mail de verificacao nao chega.
RESEND_API_KEY=""

# E-mail de origem dos e-mails transacionais. Em dev pode ser onboarding@resend.dev.
# Em prod, configure um dominio verificado no Resend e use seu proprio dominio.
RESEND_FROM_EMAIL="Sophia <onboarding@resend.dev>"

# -----------------------------------------------------------------------------
# APP_BASE_URL — URL publica da app (usada em links de e-mail)
# -----------------------------------------------------------------------------
APP_BASE_URL="http://localhost:3000"
# Em prod: https://sophia.seudominio.com (ou a URL da Vercel)

# -----------------------------------------------------------------------------
# NODE_ENV — automatico, geralmente nao precisa setar
# -----------------------------------------------------------------------------
# NODE_ENV="development"
